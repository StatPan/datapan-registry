{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.provider-index.v1.schema.json",
  "title": "Datapan Provider Index v1",
  "description": "Index of provider adapters registered in a Datapan release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "adapter_count",
    "host_count",
    "adapters",
    "split_readiness"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datapan_version": {
      "type": "string",
      "minLength": 1
    },
    "adapter_count": {
      "type": "integer",
      "minimum": 0
    },
    "host_count": {
      "type": "integer",
      "minimum": 0
    },
    "adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapter"
      }
    },
    "split_readiness": {
      "$ref": "#/$defs/split_readiness"
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "hosts", "capabilities"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["registered"]
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["verification", "call"]
          }
        }
      }
    },
    "split_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready",
        "status",
        "adapter_count",
        "verification_capable_adapters",
        "call_capable_adapters",
        "required_adapters",
        "required_verification_adapters",
        "required_call_adapters",
        "reasons",
        "recommendation"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "status": {
          "enum": ["ready", "not_ready"]
        },
        "adapter_count": {
          "type": "integer",
          "minimum": 0
        },
        "verification_capable_adapters": {
          "type": "integer",
          "minimum": 0
        },
        "call_capable_adapters": {
          "type": "integer",
          "minimum": 0
        },
        "required_adapters": {
          "type": "integer",
          "minimum": 0
        },
        "required_verification_adapters": {
          "type": "integer",
          "minimum": 0
        },
        "required_call_adapters": {
          "type": "integer",
          "minimum": 0
        },
        "reasons": {
          "type": "array",
          "items": {
            "enum": [
              "need_at_least_two_external_adapters",
              "need_at_least_two_verification_capable_adapters",
              "need_at_least_one_call_capable_adapter"
            ]
          }
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
