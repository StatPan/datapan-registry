{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.provider-index.v1.schema.json",
  "title": "Datapan Provider Index v1",
  "description": "Index of provider adapters registered in a Datapan release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "adapter_count",
    "host_count",
    "adapters"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datapan_version": {
      "type": "string",
      "minLength": 1
    },
    "adapter_count": {
      "type": "integer",
      "minimum": 0
    },
    "host_count": {
      "type": "integer",
      "minimum": 0
    },
    "adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapter"
      }
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "hosts", "capabilities"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["registered"]
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["verification", "call"]
          }
        }
      }
    }
  }
}
