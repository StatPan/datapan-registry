{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.specs.v1.schema.json",
  "title": "Datapan Specs Registry v1",
  "description": "Normalized public-data API specs preserved from upstream catalog metadata.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/spec"
  },
  "$defs": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "provider", "priority", "operations"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "type": "string"
        },
        "source_category": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "source_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "search_terms": {
          "description": "Datapan-created search helpers, not upstream metadata.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operation"
          }
        },
        "smoke": {
          "$ref": "#/$defs/smoke"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string"
        },
        "default_params": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "request_params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/param"
          }
        },
        "response_params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/param"
          }
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "param": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "smoke": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operation": {
          "type": "string"
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system"],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string"
        },
        "raw": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
