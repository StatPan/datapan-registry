{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.source-reference-drift.v1.schema.json",
  "title": "Datapan Source Reference Drift v1",
  "description": "Baseline report for official source reference URLs that must stay aligned with checked-in source profiles.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "summary",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "datapan.source-reference-drift.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datapan_version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "$defs": {
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources",
        "references",
        "manual_review_references",
        "network_checked_references",
        "changed_references",
        "missing_references",
        "contract_affecting_changes"
      ],
      "properties": {
        "sources": {
          "$ref": "#/$defs/count"
        },
        "references": {
          "$ref": "#/$defs/count"
        },
        "manual_review_references": {
          "$ref": "#/$defs/count"
        },
        "network_checked_references": {
          "$ref": "#/$defs/count"
        },
        "changed_references": {
          "$ref": "#/$defs/count"
        },
        "missing_references": {
          "$ref": "#/$defs/count"
        },
        "contract_affecting_changes": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "provider",
        "source_profile",
        "last_reviewed_at",
        "references"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/source_id"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "source_profile": {
          "type": "string",
          "minLength": 1
        },
        "last_reviewed_at": {
          "type": "string",
          "format": "date"
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "url",
        "reviewed_at",
        "check_mode",
        "drift_status",
        "contract_impact"
      ],
      "properties": {
        "kind": {
          "enum": [
            "homepage_url",
            "api_docs_url",
            "key_request_url",
            "notice_url",
            "terms_url",
            "metadata_standard_url"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date"
        },
        "check_mode": {
          "enum": ["manual_review", "network_fetch", "not_checked"]
        },
        "drift_status": {
          "enum": ["baseline", "unchanged", "changed", "redirected", "missing", "error", "unknown"]
        },
        "contract_impact": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "source_identity",
              "catalogue",
              "auth",
              "notice",
              "terms",
              "metadata_standard",
              "error_taxonomy",
              "runtime",
              "unknown"
            ]
          },
          "uniqueItems": true
        },
        "last_http_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "final_url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  }
}
