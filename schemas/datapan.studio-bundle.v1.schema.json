{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.studio-bundle.v1.schema.json",
  "title": "Datapan Studio Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "datapan_version",
    "provider",
    "output_dir",
    "limit",
    "filters",
    "files",
    "summary",
    "overview",
    "datasets",
    "next"
  ],
  "properties": {
    "schema_version": {
      "const": "datapan.studio-bundle.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datapan_version": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "registry": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "limit": {
      "type": "integer",
      "minimum": 0
    },
    "query": {
      "type": "string"
    },
    "filters": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "overview": {
      "type": "object",
      "additionalProperties": true
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "next": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_step"
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["overview", "datasets", "bundle", "viewer"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "next_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "command"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
