{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.schema-index.v1.schema.json",
  "title": "Datapan Schema Index v1",
  "description": "Index of Datapan schema files included in a release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "datapan_version",
    "count",
    "schemas"
  ],
  "properties": {
    "schema_version": {
      "const": "datapan.schema-index.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datapan_version": {
      "type": "string",
      "minLength": 1
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "schemas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/schema"
      }
    }
  },
  "$defs": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "id", "title", "contract", "version", "bytes", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^schemas/[^\\\\]+\\.schema\\.json$"
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
