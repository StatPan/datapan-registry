{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.source-profile.v1.schema.json",
  "title": "Datapan Source Profile v1",
  "description": "Source-level operating profile for public data catalogues and provider sites.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "provider",
    "display_name",
    "status",
    "references",
    "catalogue",
    "auth",
    "request",
    "response",
    "errors",
    "runtime"
  ],
  "properties": {
    "schema_version": {
      "const": "datapan.source-profile.v1"
    },
    "source_id": {
      "$ref": "#/$defs/source_id"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["candidate", "active", "deprecated", "blocked"]
    },
    "adapter": {
      "$ref": "#/$defs/adapter"
    },
    "references": {
      "$ref": "#/$defs/references"
    },
    "catalogue": {
      "$ref": "#/$defs/catalogue"
    },
    "auth": {
      "$ref": "#/$defs/auth"
    },
    "request": {
      "$ref": "#/$defs/request"
    },
    "response": {
      "$ref": "#/$defs/response"
    },
    "errors": {
      "$ref": "#/$defs/errors"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "promotion": {
      "$ref": "#/$defs/promotion"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "capabilities"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["none", "planned", "registered", "blocked"]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "enum": ["catalogue_import", "verification", "call", "normalization"]
          },
          "uniqueItems": true
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homepage_url", "last_reviewed_at"],
      "properties": {
        "homepage_url": {
          "$ref": "#/$defs/uri"
        },
        "api_docs_url": {
          "$ref": "#/$defs/uri"
        },
        "key_request_url": {
          "$ref": "#/$defs/uri"
        },
        "notice_url": {
          "$ref": "#/$defs/uri"
        },
        "terms_url": {
          "$ref": "#/$defs/uri"
        },
        "metadata_standard_url": {
          "$ref": "#/$defs/uri"
        },
        "last_reviewed_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "catalogue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model"],
      "properties": {
        "model": {
          "enum": ["portal", "statistics", "geospatial", "legislative", "single_api", "mixed"]
        },
        "list_endpoint": {
          "type": "string"
        },
        "detail_endpoint": {
          "type": "string"
        },
        "search_endpoint": {
          "type": "string"
        },
        "notice_endpoint": {
          "type": "string"
        },
        "update_cadence": {
          "type": "string"
        },
        "identity_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["none", "api_key", "service_key", "oauth2", "session", "approval_required", "mixed"]
        },
        "key_parameter_names": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "key_locations": {
          "type": "array",
          "items": {
            "enum": ["query", "header", "path", "body"]
          },
          "uniqueItems": true
        },
        "approval_scope": {
          "enum": ["none", "source", "api_family", "operation", "unknown"]
        },
        "credential_reference": {
          "type": "string"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methods", "parameter_model"],
      "properties": {
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "uniqueItems": true
        },
        "parameter_model": {
          "enum": ["query", "path", "body", "form", "mixed"]
        },
        "paging": {
          "$ref": "#/$defs/paging"
        },
        "date_range": {
          "$ref": "#/$defs/date_range"
        },
        "required_param_policy": {
          "enum": ["documented", "sample_based", "operation_specific", "unknown"]
        }
      }
    },
    "paging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["none", "page", "offset", "cursor", "date_window", "unknown"]
        },
        "page_param": {
          "type": "string"
        },
        "size_param": {
          "type": "string"
        },
        "offset_param": {
          "type": "string"
        },
        "cursor_param": {
          "type": "string"
        },
        "total_count_path": {
          "type": "string"
        }
      }
    },
    "date_range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_param": {
          "type": "string"
        },
        "end_param": {
          "type": "string"
        },
        "format": {
          "type": "string"
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formats"],
      "properties": {
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["json", "xml", "csv", "xls", "xlsx", "sdmx", "html", "geojson", "wms", "binary", "unknown"]
          },
          "uniqueItems": true
        },
        "default_format": {
          "enum": ["json", "xml", "csv", "xls", "xlsx", "sdmx", "html", "geojson", "wms", "binary", "unknown"]
        },
        "encoding": {
          "type": "string"
        },
        "envelope_path": {
          "type": "string"
        },
        "items_path": {
          "type": "string"
        },
        "schema_policy": {
          "enum": ["documented", "sample_inferred", "fingerprint_only", "unknown"]
        }
      }
    },
    "errors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taxonomy_status"],
      "properties": {
        "taxonomy_status": {
          "enum": ["unknown", "draft", "verified", "blocked"]
        },
        "status_code_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "message_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "known_error_codes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/error_code"
          }
        }
      }
    },
    "error_code": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "classification"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        },
        "classification": {
          "enum": [
            "credential",
            "approval",
            "rate_limit",
            "bad_request",
            "not_found",
            "provider_contract",
            "upstream_outage",
            "maintenance",
            "parser",
            "adapter",
            "unknown"
          ]
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verification_mode"],
      "properties": {
        "verification_mode": {
          "enum": ["none", "metadata_only", "sample_call", "bounded_call", "adapter_required"]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "retry_policy": {
          "enum": ["none", "idempotent", "backoff", "adapter_specific"]
        },
        "rate_limit_policy": {
          "enum": ["unknown", "documented", "conservative", "adapter_specific"]
        },
        "sample_param_policy": {
          "enum": ["none", "static", "generated", "catalogue_sample", "manual"]
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_status": {
          "enum": ["registry_only", "candidate", "promoted", "served"]
        },
        "mapping_reference": {
          "type": "string"
        }
      }
    }
  }
}
